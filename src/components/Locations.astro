---

---

<section id="locations" class="py-16 sm:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-blue-900 mb-4">
        היכן מתבצעות ההדרכות?
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        ניתן לקיים הדרכות במרכז שלנו או אצלכם בעסק
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
      <!-- Training Center -->
      <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl overflow-hidden border border-blue-200">
        <div class="aspect-video overflow-hidden">
          <img
            src="/images/training.webp"
            alt="הדרכת עבודה בגובה"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="p-6 sm:p-8">
          <div class="flex items-start gap-4">
            <div class="w-14 h-14 bg-blue-900 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-blue-900 mb-2">מרכז ההדרכות</h3>
              <p class="text-gray-700 mb-4">
                ביצוע הדרכות באזור תעשיה עמק חפר
              </p>
              <div class="flex items-start gap-2 text-gray-600">
                <svg class="w-5 h-5 text-blue-900 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>גשר העץ 27, פארק תעשיה עמק חפר</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- On-Site Training -->
      <div class="bg-gradient-to-br from-orange-50 to-orange-100 rounded-2xl p-6 sm:p-8 border border-orange-200 flex items-center">
        <div class="flex items-start gap-4">
          <div class="w-14 h-14 bg-orange-500 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold text-blue-900 mb-2">אצלכם בעסק</h3>
            <p class="text-gray-700 mb-4">
              ניתן לבצע הדרכות באתר הלקוח לנוחותכם המלאה
            </p>
            <div class="flex items-center gap-2 text-orange-700 font-medium">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>גמישות מלאה בתיאום מועדים</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
