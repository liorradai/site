---
const whatsappLink = "https://wa.me/972522471243?text=שלום%20ליאור,%20אשמח%20לפרטים%20לגבי%20הדרכות%20בטיחות";

const navLinks = [
  { href: "#about", label: "אודות" },
  { href: "#services", label: "תחומי הדרכה" },
  { href: "#locations", label: "מיקום" },
];
---

<header class="fixed top-0 right-0 left-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative flex items-center justify-between h-16 sm:h-20">
      <!-- Logo/Name -->
      <a href="/" class="flex items-center gap-2 text-blue-900 font-bold text-lg sm:text-xl">
        <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span class="hidden sm:inline">הדרכות בטיחות וייעוץ ליאור רדעי</span>
        <span class="sm:hidden">ליאור רדעי</span>
      </a>

      <!-- Navigation Links (Desktop) - Centered -->
      <nav class="hidden md:flex items-center gap-8 absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-gray-700 hover:text-blue-900 font-medium transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- WhatsApp CTA -->
      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white font-medium px-4 py-2 rounded-full transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span class="hidden sm:inline">שלח הודעה</span>
      </a>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <nav class="md:hidden border-t border-gray-100 bg-white">
    <div class="flex justify-center gap-6 px-4 py-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-gray-700 hover:text-blue-900 font-medium text-sm transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>
